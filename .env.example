# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini
OPENAI_MAX_COMPLETION_TOKENS=4096
OPENAI_TIMEOUT_MS=120000
OPENAI_ENABLED=true

# Optional. For most GPT-5 family models keep this unset.
# OPENAI_TEMPERATURE=0.3

# Server
PORT=3000
NODE_ENV=development

# Optional news JSON endpoint. Supports an array payload, { "items": [...] }, or { "data": [...] }.
# NEWS_JSON_URL=https://example.com/webstock-news.json

# Optional authorized Level-2 market data gateway.
# Use this only with a licensed provider API or local gateway. Do not reverse-engineer a retail quote client.
# LEVEL2_PROVIDER=tonghuashun-http
# LEVEL2_BASE_URL=http://127.0.0.1:18180
# LEVEL2_API_KEY=
# LEVEL2_AUTH_HEADER=Authorization
# LEVEL2_AUTH_PREFIX=Bearer
# LEVEL2_DEPTH_ENDPOINT=/depth?code={code}
# LEVEL2_TRADES_ENDPOINT=/trades?code={code}&limit={limit}
# LEVEL2_ORDERS_ENDPOINT=/orders?code={code}&limit={limit}
# LEVEL2_TIMEOUT_MS=5000
# LEVEL2_LARGE_ORDER_THRESHOLD=500000
# LEVEL2_VOLUME_UNIT=share
